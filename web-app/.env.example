# Database
# - ホストで pnpm run dev / pnpm run build する場合: この値が使われます（ホスト名は localhost）
# - Docker Compose で web コンテナを起動する場合: compose.yml の DATABASE_URL 環境変数で上書きされます（コンテナ間接続のホスト名は db）
DATABASE_URL=postgresql://user:password@localhost:5432/dailygreen

# Better Auth (32+ chars). Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=

BETTER_AUTH_URL=http://localhost:5173

# Google OAuth
# リダイレクトURI: {BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
